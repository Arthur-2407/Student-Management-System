# Database Configuration
DB_PASSWORD=your_secure_postgres_password
DB_HOST=student-db
DB_PORT=5434
DB_NAME=student_system
DB_USER=postgres
FACE_DB_HOST=student-face-db
FACE_DB_PORT=5435
FACE_DB_NAME=student_face_system
FACE_DB_USER=face_admin

# Redis Configuration
REDIS_PASSWORD=your_secure_redis_password

# JWT Configuration
JWT_ACCESS_SECRET=your_super_secret_jwt_access_key_change_in_production
JWT_REFRESH_SECRET=your_super_secret_jwt_refresh_key_change_in_production
E2E_BYPASS_KEY=your_super_secret_e2e_bypass_key_change_in_production
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Face AI Service Configuration
FACE_AI_SERVICE_URL=http://student-face-ai:8000
MODEL_PATH=/app/models
FACE_AI_TIMEOUT_MS=15000

# Frontend Configuration
FRONTEND_URL=http://localhost:8080
API_URL=http://localhost:3002
FACE_AI_URL=http://localhost:8001

# SSL Configuration
SSL_CERT_PATH=/etc/nginx/ssl/server.crt
SSL_KEY_PATH=/etc/nginx/ssl/server.key

# Monitoring and Logging
LOG_LEVEL=info
ENABLE_METRICS=true

# Security
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
ENABLE_CORS=true
CORS_ORIGIN=http://localhost:8080

# Backup Configuration
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30
BACKUP_S3_BUCKET=your-backup-bucket

# Email Configuration (for notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@yourdomain.com
