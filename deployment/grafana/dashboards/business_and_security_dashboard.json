            "uid": "${datasource}"
          },
          "editorMode": "code",
          "expr": "histogram_quantile(0.90, sum(rate(ai_confidence_scores_bucket[5m])) by (le))",
          "legendFormat": "p90 Confidence Score",
          "refId": "A"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "editorMode": "code",
          "expr": "histogram_quantile(0.90, sum(rate(ai_deepfake_detection_score_bucket[5m])) by (le))",
          "legendFormat": "p90 Deepfake Score",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line"
          },
          "unit": "percentunit"
        }
      }
